// Sportsun Factory ERP — schema
// Product is the single master (Catalog + Style merged). Style is retained but
// deprecated (seed-time read-model only); the /styles route is retired.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum VendorKind {
  EXTERNAL
  INHOUSE
}

enum FabricUnit {
  KG
  MTR
}

// Knitted fabric is held either OPEN (flat) or TUBE (circular). Master default.
enum FabricForm {
  OPEN
  TUBE
}

enum JobStatus {
  ACTIVE
  CLOSED
}

// "Overdue" is derived (isOverdue from plannedEtd), not stored.
// The real shop-floor flow (Change 12, Part B). STITCHING is kept valid for legacy
// rows and normalised to ON_MACHINE on read (see normStage in job-labels.ts).
enum JobStage {
  FABRIC_AWAITED
  CUTTING
  ON_MACHINE
  FINISHING
  DISPATCH
  STITCHING
}

enum MovementType {
  ISSUE
  RECEIPT
}

// Why a dispatch/production row left stock (Change 10, Part H).
enum DispatchReason {
  ORDER
  SALE
  OTHER
}

// Materials challan direction (Change 11).
enum ChallanDirection {
  INWARD // from a Supplier -> our master stock (adds)
  OUTWARD // to a Vendor -> from our master stock (subtracts)
}

enum ChallanStatus {
  DRAFT // editable
  LOCKED // numbered & posted to inventory; no further line edits
}

enum Role {
  ADMIN
  STAFF
  VENDOR
  TRIMS // column/scope-limited persona (e.g. Satya — trims only)
}

enum ProductStatus {
  ACTIVE
  NEW_ARTICLE
  FUTURE_PLAN
  DISCONTINUED
  IN_PROCESS
}

enum ProductionStatus {
  ORDER_GIVEN
  IN_PRODUCTION
  COMPLETED
}

// How a BOM line's trim is consumed against the size×colour matrix.
enum BomDimension {
  COLOR // explode × that colour's cut qty
  SIZE // explode × that size's cut qty
  FLAT // same on every piece (× total cut qty)
}

enum SupplierType {
  CHINA
  IMPORTER
  AGENT
  MANUFACTURER
}

// The 7 head trim categories (unified from the fragmented trim databases).
enum TrimCategory {
  BUTTON
  ZIP
  TAG
  CARDBOARD
  MASTERPACK
  LABEL
  POLYBAG // packaging / panni
  OTHER
}

enum TrimStatus {
  ACTIVE
  PLANNING
  DISCONTINUED
}

enum FabricOrderStatus {
  PLANNING
  SAMPLE_PENDING
  ORDER_PLACED
  RECEIVED
  DISCARDED
}

enum SamplingStatus {
  PLANNING
  DESIGN_FABRIC_PENDING
  SAMPLE_ORDERED
  READY
}

enum ProductionLot {
  OLD_CUT_SIZE
  NEW_LOT
}

model Vendor {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  kind              VendorKind         @default(EXTERNAL)
  active            Boolean            @default(true)
  jobCards          JobCard[]
  stitchAssignments StitchAssignment[]
  materialChallans  MaterialChallan[]
}

model CuttingMaster {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  active        Boolean        @default(true)
  jobCards      JobCard[]
  cuttingLayers CuttingLayer[]
}

model Fabric {
  id           Int             @id @default(autoincrement())
  name         String          @unique
  unit         FabricUnit      @default(MTR)
  openingStock Float           @default(0)
  ratePerUnit  Float? // estimated price per unit (KG/MTR)
  // master presets — defaults applied at point of use (lay/job card), overridable
  gsm          Float?
  rollWidth    Float?
  form         FabricForm?
  styles         Style[]
  products       Product[]
  colors         FabricColor[]
  suppliers      FabricSupplier[]
  movements      StockMovement[]
  returnNotes    ReturnNote[]
  jobFabricLines JobFabricLine[]
  fabricOrders   FabricOrder[]
  images         ImageAsset[]
  challanLines   MaterialChallanLine[]
}

// Stock is held per colour under each fabric (factory holds finished, dyed fabric
// per colour). currentStock is the authoritative snapshot (mirrors TrimItem.currentStock).
model FabricColor {
  id           Int    @id @default(autoincrement())
  color        String
  openingStock Float  @default(0)
  currentStock Float  @default(0)
  fabric       Fabric @relation(fields: [fabricId], references: [id], onDelete: Cascade)
  fabricId     Int

  @@unique([fabricId, color])
  @@index([fabricId])
}

// A fabric can have several suppliers (lightweight).
model FabricSupplier {
  id       Int    @id @default(autoincrement())
  name     String
  rate     Float?
  fabric   Fabric @relation(fields: [fabricId], references: [id], onDelete: Cascade)
  fabricId Int

  @@index([fabricId])
}

/// @deprecated — production styles are merged into Product (the single master).
/// Kept as a seed-time read-model; the /styles route redirects to /catalog.
model Style {
  id             Int        @id @default(autoincrement())
  styleNo        String     @unique
  sku            String?
  itemDesc       String
  mrp            Float?
  category       String?
  avgConsumption Float?
  unit           FabricUnit @default(MTR)
  fabric         Fabric?    @relation(fields: [fabricId], references: [id])
  fabricId       Int?
}

model JobCard {
  id            Int       @id @default(autoincrement())
  siNo          String
  orderDate     DateTime?
  cutQty        Float     @default(0)
  dispatchedQty Float     @default(0)

  // estimate (auto snapshot from product at create)
  estAvg           Float?
  estFabric        Float?
  // actual (entered later by staff)
  actualAvg        Float?
  fabricDispatched Float?
  fabricUsed       Float?
  // legacy (historical seed data)
  avgConsumption   Float?
  fabricIssued     Float?
  fabricConsumed   Float?

  fabricIssueDate DateTime?
  cuttingIssuedOn DateTime?
  plannedEtd      DateTime?
  status          JobStatus @default(ACTIVE)
  stage           JobStage  @default(CUTTING)
  remark          String?
  trimsPending    Boolean   @default(false) // set when BOM needs exceed trim stock at save (Pending Trims)

  // header additions (Change 10, Part E) — process flags marked X on the paper form
  needsPrint   Boolean @default(false)
  needsLaser   Boolean @default(false)
  needsEmb     Boolean @default(false)
  merchandiser String? // person handling the cutting, e.g. "Jyotika"
  mrp          Float? // owner-visible only (canSeeCost)

  // made-to-order fallback (Change 12, Part D) — used when there is no catalogue product
  // (SKU shows ORDER / TBC / NEW STYLE). A job card must have either productId or customItem.
  customItem  String? // e.g. "JHARKHAND TRACKSUIT"
  customSku   String? // e.g. "ORDER" / "TBC" / a hand code
  customStyle String? // e.g. "#1202"
  customMrp   Float? // owner-visible only, when there's no product MRP

  // optional quality/quantity capture (Change 12, Part G) — never required
  rejectQty Float? // "18 PCS REJECT"
  alterQty  Float? // "262 PCS IN ALTER"
  extraQty  Float? // "39 PCS EXTRA"

  product         Product?       @relation(fields: [productId], references: [id])
  productId       Int?
  vendor          Vendor         @relation(fields: [vendorId], references: [id])
  vendorId        Int
  cuttingMaster   CuttingMaster? @relation(fields: [cuttingMasterId], references: [id])
  cuttingMasterId Int?

  dispatches        DispatchEvent[]
  sizeBreakup       SizeBreakup[]
  jobLines          JobBomLine[]
  fabricLines       JobFabricLine[]
  returnNotes       ReturnNote[]
  movements         StockMovement[]
  layers            CuttingLayer[]
  stitchAssignments StitchAssignment[]

  @@index([vendorId])
  @@index([productId])
}

// A single lay (Change 10, Part B). A production run is cut in several layers, each
// its own colour×size table + its own fabric maths + optional date/master.
model CuttingLayer {
  id              Int            @id @default(autoincrement())
  jobCard         JobCard        @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  jobCardId       Int
  layerNo         Int // 1,2,3… order within the card
  label           String? // optional, e.g. "LAYER-1 #512"
  cutDate         DateTime? // this layer may be cut on its own date
  cuttingMaster   CuttingMaster? @relation(fields: [cuttingMasterId], references: [id])
  cuttingMasterId Int? // this layer may be cut by its own master

  // per-layer fabric maths (Part C)
  avgConsumption Float? // m per piece, e.g. 0.781
  rolls          Int? // roll count used, e.g. 11
  fabricMtr      Float? // total fabric for this layer, e.g. 1100
  fabricBalance  Float? // leftover after this layer, may be negative

  cells CuttingLayerCell[]

  @@index([jobCardId])
}

model CuttingLayerCell {
  id      Int          @id @default(autoincrement())
  layer   CuttingLayer @relation(fields: [layerId], references: [id], onDelete: Cascade)
  layerId Int
  colour  String // canonical colour string (colorKey, matches Change 08)
  size    String // S, M, L, XL, 2XL, 3XL …
  qty     Float

  @@index([layerId])
}

// One card's stitching can fan out to several vendors (Change 10, Part G), each with
// its own lot, received log, and derived balance; a vendor may be routed a colour.
model StitchAssignment {
  id        Int             @id @default(autoincrement())
  jobCard   JobCard         @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  jobCardId Int
  vendor    Vendor          @relation(fields: [vendorId], references: [id])
  vendorId  Int
  colour    String? // optional: this vendor stitches only this colour (e.g. "only BLACK")
  lotQty    Float? // pieces assigned to this vendor (their "LOT")
  note      String? // e.g. "stitch & finishing in Ramanreti"
  receipts  StitchReceipt[]

  @@index([jobCardId])
  @@index([vendorId])
}

model StitchReceipt {
  id           Int              @id @default(autoincrement())
  assignment   StitchAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId Int
  date         DateTime
  qty          Float
  note         String?

  @@index([assignmentId])
}

// Per-colour fabric line on a job card: one style is cut in 1–10 colours together,
// each drawing from that colour's stock. Assumed avg defaults from the product;
// actual avg + used are logged after cutting. gsm/rollWidth null ⇒ inherit the
// fabric master preset (they vary roll-to-roll, overridable at the lay).
model JobFabricLine {
  id        Int     @id @default(autoincrement())
  color     String
  fabric    Fabric  @relation(fields: [fabricId], references: [id])
  fabricId  Int
  cutQty    Float   @default(0)
  estAvg    Float?
  actualAvg Float?
  gsm       Float?
  rollWidth Float?
  qtyIssued Float?
  qtyUsed   Float?
  arrangedBy String? // who issued the fabric (defaults to logged-in user)
  challan    String?
  // fabric-detail plan per colour (Change 10, Part F)
  reqPcs    Float? // planned pieces for this colour
  reqMtr    Float? // planned fabric metres for this colour
  rolls     Int? // planned/used roll count for this colour
  imageUrl  String? // per-colour fabric swatch/photo (reuse Change 06 upload)
  jobCard   JobCard @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  jobCardId Int

  @@index([jobCardId])
  @@index([fabricId])
}

model DispatchEvent {
  id         Int            @id @default(autoincrement())
  date       DateTime
  qty        Float
  challan    String?
  note       String?
  arrangedBy String? // who logged the receipt (defaults to logged-in user)
  reason     DispatchReason @default(ORDER) // ORDER / SALE / OTHER (Change 10, Part H)
  jobCard    JobCard        @relation(fields: [jobCardId], references: [id])
  jobCardId  Int

  @@index([jobCardId])
}

model SizeBreakup {
  id        Int     @id @default(autoincrement())
  size      String
  color     String  @default("") // size×color matrix; "" = colorless/legacy row
  qty       Float
  jobCard   JobCard @relation(fields: [jobCardId], references: [id])
  jobCardId Int

  @@index([jobCardId])
}

// Frozen BOM snapshot of what a job card actually consumed (immutable even if the
// product BOM later changes). Drives real-time trim depletion at job creation.
model JobBomLine {
  id          Int          @id @default(autoincrement())
  material    String
  color       String?
  dimension   BomDimension @default(FLAT)
  perPieceQty Float?
  totalQty    Float? // legacy: perPieceQty × cutQty
  requiredQty Float? // exploded need against the matrix (the amount depleted)
  issuedQty   Float?       @default(0) // logged over time; balance = requiredQty - issuedQty (derived)
  arrangedBy  String?
  issueDate   DateTime?
  challan     String?
  trimItem    TrimItem?    @relation(fields: [trimItemId], references: [id])
  trimItemId  Int?
  jobCard     JobCard      @relation(fields: [jobCardId], references: [id])
  jobCardId   Int

  @@index([jobCardId])
  @@index([trimItemId])
}

// Auto-generated when actual fabric dispatched > used. The stock add-back is a
// StockMovement RECEIPT; this is the human-facing return artifact.
model ReturnNote {
  id        Int      @id @default(autoincrement())
  qty       Float
  date      DateTime @default(now())
  note      String?
  color     String? // null for legacy/colourless returns
  fabric    Fabric   @relation(fields: [fabricId], references: [id])
  fabricId  Int
  jobCard   JobCard  @relation(fields: [jobCardId], references: [id])
  jobCardId Int

  @@index([jobCardId])
  @@index([fabricId])
}

model StockMovement {
  id        Int          @id @default(autoincrement())
  type      MovementType
  qty       Float
  date      DateTime
  note      String?
  color     String? // null for legacy/colourless movements
  fabric    Fabric       @relation(fields: [fabricId], references: [id])
  fabricId  Int
  jobCard   JobCard?     @relation(fields: [jobCardId], references: [id])
  jobCardId Int?

  @@index([fabricId])
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  displayName  String
  role         Role     @default(STAFF)
  vendorName   String? // for VENDOR role: matches Vendor.name verbatim
  createdAt    DateTime @default(now())

  @@index([role])
}

// ── Product = the single master (commercial catalog + production spec) ──
model Product {
  id           Int           @id @default(autoincrement())
  extId        String        @unique
  skuCode      String
  normSku      String
  styleNo      String?
  name         String
  itemDesc     String? // workbook item description (for job autofill + list "item")
  headCategory String?
  mrp          Float?
  customWsRate Float?
  status       ProductStatus @default(ACTIVE)
  styleGroup   String?
  bomCode      String?

  // production-master fields (merged from Style)
  avgConsumption Float?
  unit           FabricUnit @default(MTR)
  fabric         Fabric?    @relation(fields: [fabricId], references: [id])
  fabricId       Int?
  imageUrl       String?
  sizeRatioJson  String? // JSON [["S",0.08],...] — per-product configurable size ratio
  colorRatioJson String? // JSON [["RED",0.5],...] — default color split
  // production/sampling attributes (Change 07 — from Notion product master)
  samplingStatus SamplingStatus?
  productionLot  ProductionLot?
  fabricRemarks  String?
  otherRemarks   String?

  colors           ProductColor[]
  jobCards         JobCard[]
  boms             Bom[]
  productionOrders ProductionOrder[]
  images           ImageAsset[]

  @@index([headCategory])
  @@index([normSku])
  @@index([fabricId])
}

model ProductColor {
  id        Int     @id @default(autoincrement())
  name      String
  hex       String?
  sortOrder Int?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int

  @@unique([productId, name])
  @@index([productId])
}

model Bom {
  id        Int       @id @default(autoincrement())
  code      String
  styleName String
  product   Product?  @relation(fields: [productId], references: [id])
  productId Int?
  lines     BomLine[]

  @@index([productId])
}

model BomLine {
  id          Int          @id @default(autoincrement())
  sNo         Int?
  material    String
  color       String?
  qty         Float? // legacy per-piece qty (kept for migration)
  perPieceQty Float? // source going forward (per-one-piece count)
  dimension   BomDimension @default(FLAT)
  avg         String?
  bom         Bom          @relation(fields: [bomId], references: [id])
  bomId       Int
  trimItem    TrimItem?    @relation(fields: [trimItemId], references: [id])
  trimItemId  Int?

  @@index([bomId])
  @@index([trimItemId])
}

model TrimItem {
  id           Int            @id @default(autoincrement())
  sno          String?
  name         String         @unique
  normName     String
  family       String? // legacy free-text family (kept for back-compat)
  openingStock Float          @default(0)
  currentStock Float          @default(0) // authoritative snapshot
  // unified trim master fields
  category     TrimCategory?
  supplier     Supplier?      @relation(fields: [supplierId], references: [id])
  supplierId   Int?
  ratePerUnit  Float?
  unit         String? // pcs / mtr / kg / set
  status       TrimStatus     @default(ACTIVE)
  remarks      String?
  imageUrl     String?
  // optional spec fields (surfaced per category, never forced)
  size          String?
  material      String?
  weight        String?
  shape         String?
  color         String?
  estMonthlyReq Float? // OWNER-PLANNING only — hidden from the staff entry form
  movements    TrimMovement[]
  bomLines     BomLine[]
  jobLines     JobBomLine[]
  images       ImageAsset[]
  challanLines MaterialChallanLine[]

  @@index([normName])
  @@index([family])
  @@index([category])
  @@index([supplierId])
}

// Shared supplier master (fabric orders + every trim category point here).
model Supplier {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  type         SupplierType?
  city         String?
  phone        String?
  address      String? // for the PO document
  email        String? // for the PO email (mailto)
  remarks      String?
  active           Boolean           @default(true)
  trims            TrimItem[]
  fabricOrders     FabricOrder[]
  materialChallans MaterialChallan[]

  @@index([type])
}

// Global colour master (Change 08) — powers the colour dropdown; order lines store a string.
model Colour {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  hex       String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Generic master for every simple reusable dropdown list (Change 09). Stable `code`
// (never changes), editable `label`. parentId gives category → sub-category.
enum LookupKind {
  HEAD_CATEGORY
  SUB_CATEGORY
  UNIT
  SUPPLIER_TYPE
  TRIM_CATEGORY
  STYLE_GROUP
}

model Lookup {
  id        Int        @id @default(autoincrement())
  kind      LookupKind
  code      String
  label     String
  hex       String?
  parentId  Int?
  parent    Lookup?    @relation("LookupTree", fields: [parentId], references: [id])
  children  Lookup[]   @relation("LookupTree")
  sortOrder Int        @default(0)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())

  @@unique([kind, code])
  @@index([kind, parentId])
}

// Procurement pipeline that feeds fabric INTO colour stock.
model FabricOrder {
  id            Int               @id @default(autoincrement())
  fabric        Fabric            @relation(fields: [fabricId], references: [id])
  fabricId      Int
  color         String? // legacy single-colour (pre-Change-08 rows); new orders use lines[]
  supplier      Supplier?         @relation(fields: [supplierId], references: [id])
  supplierId    Int?
  qty           Float // legacy total; new orders derive total from lines
  unit          FabricUnit        @default(MTR)
  rate          Float?
  gsm           Float?
  colorCount    Int?
  status        FabricOrderStatus @default(PLANNING)
  shadeCardDone Boolean           @default(false)
  orderDate     DateTime?
  expectedDate  DateTime?
  receivedDate  DateTime? // set on receive — also the double-receive guard
  remarks       String?
  // PO (Change 08)
  poNumber      String?           @unique // e.g. PO-2026-001 — set when PO generated, locks the order
  poGeneratedAt DateTime?
  sentAt        DateTime? // set when emailed/WhatsApp-shared
  lines         FabricOrderLine[]
  images        ImageAsset[]

  @@index([fabricId])
  @@index([supplierId])
  @@index([status])
}

// One colour + quantity row of a multi-colour fabric order (Change 08).
model FabricOrderLine {
  id            Int         @id @default(autoincrement())
  fabricOrder   FabricOrder @relation(fields: [fabricOrderId], references: [id], onDelete: Cascade)
  fabricOrderId Int
  colour        String // canonical colour string (colorKey)
  qty           Float

  @@index([fabricOrderId])
}

model TrimMovement {
  id         Int          @id @default(autoincrement())
  type       MovementType
  qty        Float
  date       DateTime?
  invoice    String?
  rate       Float?
  vendor     String?
  trimItem   TrimItem     @relation(fields: [trimItemId], references: [id])
  trimItemId Int

  @@index([trimItemId])
}

// Generic image gallery — nullable FKs let one table serve every entity, many per entity.
model ImageAsset {
  id        Int      @id @default(autoincrement())
  url       String
  thumbUrl  String?
  caption   String?
  kind      String? // "product" | "swatch" | "shade_card" | "trim"
  sortOrder Int?
  createdAt DateTime @default(now())

  trimItem      TrimItem?    @relation(fields: [trimItemId], references: [id], onDelete: Cascade)
  trimItemId    Int?
  fabric        Fabric?      @relation(fields: [fabricId], references: [id], onDelete: Cascade)
  fabricId      Int?
  fabricOrder   FabricOrder? @relation(fields: [fabricOrderId], references: [id], onDelete: Cascade)
  fabricOrderId Int?
  product       Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId     Int?

  @@index([trimItemId])
  @@index([fabricId])
  @@index([fabricOrderId])
  @@index([productId])
}

model ProductionOrder {
  id             Int              @id @default(autoincrement())
  orderNo        String           @unique
  product        Product          @relation(fields: [productId], references: [id])
  productId      Int
  orderDate      DateTime?
  targetQty      Float
  avgMonthlySale Float?
  status         ProductionStatus @default(ORDER_GIVEN)
  urgency        String?
  remarks        String?

  @@index([productId])
}

// Standalone materials challan (Change 11) — inward (from supplier) / outward (to vendor)
// for fabric + trims + accessories, independent of any job card. Posts to the ONE master
// inventory ledger on lock.
model MaterialChallan {
  id        Int              @id @default(autoincrement())
  direction ChallanDirection
  status    ChallanStatus    @default(DRAFT)
  challanNo String?          @unique // e.g. "CH-OUT-2026-001" / "CH-IN-2026-001" (set on lock)
  date      DateTime         @default(now())

  // counterparty: exactly one side is set based on direction
  supplier   Supplier? @relation(fields: [supplierId], references: [id]) // INWARD
  supplierId Int?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id]) // OUTWARD
  vendorId   Int?

  note      String?
  lockedAt  DateTime?
  voidedAt  DateTime?
  lines     MaterialChallanLine[]
  createdAt DateTime              @default(now())

  @@index([direction])
  @@index([vendorId])
  @@index([supplierId])
}

model MaterialChallanLine {
  id        Int             @id @default(autoincrement())
  challan   MaterialChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
  challanId Int

  // a line is EITHER a fabric line (with colour) OR a trim/accessory line
  fabric     Fabric?   @relation(fields: [fabricId], references: [id])
  fabricId   Int?
  colour     String? // for fabric lines (colorKey, matches Change 08)
  trimItem   TrimItem? @relation(fields: [trimItemId], references: [id])
  trimItemId Int?

  qty  Float
  unit String? // MTR / KG / PCS / SET
  rate Float? // optional ₹/unit
  note String?

  @@index([challanId])
  @@index([fabricId])
  @@index([trimItemId])
}
